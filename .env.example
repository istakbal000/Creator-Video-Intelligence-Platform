# Environment Variables — Creator Video Intelligence Platform

# ─── AI / LLM ───────────────────────────────────────────────
GOOGLE_API_KEY=your_google_gemini_api_key_here

# ─── VECTOR DATABASE ─────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=video_transcripts
# Optional: set if your Qdrant instance requires an API key
QDRANT_API_KEY=

# ─── SERVER ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── WHISPER ─────────────────────────────────────────────────
# Path to the yt-dlp binary (must be installed separately)
YTDLP_PATH=yt-dlp
# Whisper model size: tiny | base | small | medium | large
WHISPER_MODEL=base
# Temp directory for audio downloads
TEMP_DIR=./tmp

# ─── CACHE ───────────────────────────────────────────────────
# Cache TTL in seconds (default 24h)
CACHE_TTL=86400

# ─── RATE LIMITING ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── CHUNKING ────────────────────────────────────────────────
CHUNK_SIZE=600
CHUNK_OVERLAP=100
VECTOR_TOP_K=5
